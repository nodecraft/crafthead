{
	"name": "crafthead",
	"version": "1.0.0",
	"repository": "git@github.com:nodecraft/crafthead.git",
	"license": "MIT",
	"author": "Andrew Steinborn <git@steinborn.me>",
	"main": "worker/index.js",
	"type": "module",
	"scripts": {
		"build": "wasm-pack build --release -t web",
		"check-types": "npm run check-types:server",
		"check-types:server": "tsc --noemit",
		"dev": "wrangler dev",
		"extract-hytale-assets": "node scripts/extract-hytale-assets.ts",
		"upload-assets-to-r2": "node scripts/upload-assets-to-r2.ts",
		"lint": "npm run lint:js && npm run lint:rs && npm run check-types",
		"lint:js": "eslint \"**/*.{js,mjs,cjs,ts,json}\"",
		"lint:js:fix": "npm run lint:js -- --fix",
		"lint:rs": "cargo fmt --all --check && cargo clippy --all-targets --all-features",
		"lint:rs:fix": "cargo fmt --all && cargo clippy --all-targets --all-features --fix",
		"test": "vitest --run && cargo test && cargo test -p hytale-skin-renderer",
		"test:dev": "vitest --watch"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "3.1028.0",
		"@cloudflare/vitest-pool-workers": "0.14.3",
		"@cloudflare/workers-types": "4.20260410.1",
		"@nodecraft/eslint-config": "48.1.1",
		"@stylistic/eslint-plugin": "5.10.0",
		"@types/node": "24.12.2",
		"@types/picomatch": "4.0.3",
		"@types/yauzl": "2.10.3",
		"dotenv": "17.4.1",
		"eslint": "10.2.0",
		"eslint-plugin-import-newlines": "2.0.0",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-n": "17.24.0",
		"eslint-plugin-unicorn": "64.0.0",
		"image-size": "2.0.2",
		"p-limit": "7.3.0",
		"picomatch": "4.0.4",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.1",
		"vitest": "4.1.4",
		"wrangler": "4.81.1",
		"yauzl": "3.3.0"
	},
	"engines": {
		"node": ">= 24"
	}
}
